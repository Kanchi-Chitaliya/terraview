# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# --- LLM providers (fill in at least one) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Provider selection ---
# Options: anthropic | openai | ollama
TERRAVIEW_PROVIDER=anthropic

# --- Model (defaults shown) ---
TERRAVIEW_MODEL=claude-sonnet-4-6
# TERRAVIEW_MODEL=gpt-4o

# --- Tuning ---
TERRAVIEW_MAX_TOKENS=8192

# --- Custom OpenAI-compatible endpoint (optional) ---
# TERRAVIEW_BASE_URL=http://localhost:11434/v1
